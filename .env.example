# Copy to .env and fill in from Supabase Dashboard → Project Settings → API.
# The app runs fully on mock data when these are absent — no crash, no setup needed.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Telegram bot. The bot also accepts VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY
# as fallbacks, but explicit bot env vars are cleaner in production.
TELEGRAM_BOT_TOKEN=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SITE_URL=
CRON_SECRET=

# Optional but recommended in Vercel:
# set to your public production URL, for example https://your-project.vercel.app
# so Supabase confirmation emails never fall back to localhost.
VITE_SITE_URL=
